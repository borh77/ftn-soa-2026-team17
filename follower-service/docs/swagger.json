                    "application/json"
                ],
                "tags": [
                    "followers"
                ],
                "summary": "Check if user can comment on author's blog",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Follower user ID",
                        "name": "followerId",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Blog author user ID",
                        "name": "authorId",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
