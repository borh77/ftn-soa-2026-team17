{
  "Grpc": {
    "TourServiceUrl": "http://tour-service:81"
  },
  "ReverseProxy": {
    "Routes": {
      "blog-route": {
        "ClusterId": "blog-cluster",
        "Match": {
          "Path": "/blog/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      },
      "stakeholders-root-docs": {
        "ClusterId": "stakeholders-cluster",
        "Match": {
          "Path": "/v3/api-docs/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/v3/api-docs/{**catch-all}"
          }
        ]
      },
      "stakeholders-route": {
        "ClusterId": "stakeholders-cluster",
        "Match": {
          "Path": "/stakeholders/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      },
      "follower-route": {
        "ClusterId": "follower-cluster",
        "Match": {
          "Path": "/follower/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      },
      "tours-route": {
        "ClusterId": "tour-rest-cluster",
        "Match": {
          "Path": "/tours/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "blog-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://blog-service:80/"
          }
        }
      },
      "stakeholders-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://stakeholders-service:8080/"
          }
        }
      },
      "follower-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://follower-service:8082/"
          }
        }
      },
      "tour-rest-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://tour-service:80/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
